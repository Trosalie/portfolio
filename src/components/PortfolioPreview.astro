---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'> | CollectionEntry<'work-en'>;
	basePath?: string;
}

const { data, id } = Astro.props.project;
const basePath = Astro.props.basePath ?? '/work/';
---

<a class="card" href={`${basePath}${id}`} style={`background: ${data.gradient ?? 'var(--gradient-subtle)'}`}>
	{data.img && <img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />}
	<span class="title">{data.title}</span>
	<div class="bottom">
		<ul class="tags">
			{data.tags.map((tag) => <li class="tag">{tag}</li>)}
		</ul>
		<p class="description">{data.description}</p>
	</div>
</a>

<style>
	.card {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 16rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		transition: box-shadow var(--theme-transition);
		padding: 0.5rem;
		gap: 0.5rem;
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: 0;
	}

	.title {
		align-self: flex-start;
		z-index: 1;
		padding: 0.5rem 1rem;
		background: var(--gray-999);
		color: var(--gray-200);
		border-radius: 0.375rem;
		line-height: 1.2;
	}

	.bottom {
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tag {
		padding: 0.2rem 0.6rem;
		background: var(--gray-999);
		color: var(--gray-300);
		border-radius: 0.375rem;
		font-family: var(--font-body);
		font-size: var(--text-xs, 0.75rem);
		font-weight: 500;
		white-space: nowrap;
	}

	.description {
		margin: 0;
		padding: 0.6rem 0.9rem;
		background: var(--gray-999);
		color: var(--gray-300);
		border-radius: 0.375rem;
		font-family: var(--font-body);
		font-size: var(--text-sm);
		font-weight: 400;
		line-height: 1.5;
	}

	@media (min-width: 50em) {
		.card {
			height: 22rem;
			min-height: unset;
			border-radius: 1.5rem;
			padding: 0.75rem;
		}

		.tags {
			flex-wrap: nowrap;
			overflow: hidden;
		}

		.title {
			border-radius: 0.9375rem;
		}

		.tag {
			border-radius: 0.9375rem;
		}

		.description {
			border-radius: 0.9375rem;
			display: -webkit-box;
			-webkit-line-clamp: 4;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}
	}
</style>
