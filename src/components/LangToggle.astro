---
import { getLangFromUrl, getAlternateLangPath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const alternatePath = getAlternateLangPath(Astro.url);
const ariaLabel = lang === 'fr' ? 'Switch to English' : 'Passer en Français';
const isEn = lang === 'en';
---

<a
	href={alternatePath}
	class:list={['lang-switch', { 'is-en': isEn }]}
	aria-label={ariaLabel}
	title={ariaLabel}
	role="switch"
	aria-checked={isEn ? 'true' : 'false'}
>
	<span class="label label-fr">FR</span>
	<span class="label label-en">EN</span>
</a>

<style>
	.lang-switch {
		display: flex;
		align-items: center;
		border: 0;
		border-radius: 999rem;
		padding: 0;
		background-color: var(--gray-999);
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		text-decoration: none;
		cursor: pointer;
	}

	.label {
		z-index: 1;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.375rem 0.625rem;
		width: 2.25rem;
		height: 2rem;
		font-size: var(--text-sm);
		font-family: var(--font-brand);
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--accent-overlay);
	}

	/* Glissière : positionnée sur FR par défaut */
	.label-fr::before {
		content: '';
		z-index: -1;
		position: absolute;
		inset: 0;
		background-color: var(--accent-regular);
		border-radius: 999rem;
	}

	/* Quand on est sur EN, la glissière glisse vers la droite */
	.is-en .label-fr::before {
		transform: translateX(100%);
	}

	/* Étiquette active en blanc */
	.lang-switch:not(.is-en) .label-fr,
	.is-en .label-en {
		color: var(--accent-text-over);
	}

	@media (prefers-reduced-motion: no-preference) {
		.label,
		.label-fr::before {
			transition:
				transform var(--theme-transition),
				color var(--theme-transition);
		}
	}

	@media (forced-colors: active) {
		.label-fr::before {
			background-color: SelectedItem;
		}
	}
</style>
