---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import ContactCTA from '../../../components/ContactCTA.astro';
import Hero from '../../../components/Hero.astro';
import Icon from '../../../components/Icon.astro';
import Pill from '../../../components/Pill.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'work-en'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work-en');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/en/work/"><Icon icon="arrow-left" /> Back to projects</a>
					<Hero title={entry.data.title} align="start">
						<div class="details">
							<div class="tags">
								{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
							</div>
							<p class="description">{entry.data.description}</p>
							{entry.data.githubUrl && (
								<a class="github-link" href={entry.data.githubUrl} target="_blank" rel="noopener noreferrer">
									<Icon icon="github-logo" />
									View on GitHub
								</a>
							)}
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					{entry.data.img && <img src={entry.data.img} alt={entry.data.img_alt || ''} />}
					<div class="content">
						<Content />
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		color: var(--gray-300);
		text-decoration: none;
		font-size: var(--text-sm);
		font-weight: 500;
		align-self: flex-start;
		transition: border-color var(--theme-transition), color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus {
		color: var(--accent-regular);
		border-color: var(--accent-regular);
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1.25rem;
		background: var(--gray-999);
		color: var(--gray-200);
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		text-decoration: none;
		font-size: var(--text-sm);
		font-weight: 500;
		transition: border-color var(--theme-transition), color var(--theme-transition);
	}

	.github-link:hover,
	.github-link:focus {
		color: var(--accent-regular);
		border-color: var(--accent-regular);
	}

	.github-link :global(svg) {
		width: 1.2em;
		height: 1.2em;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.content {
		max-width: 65ch;
		margin-inline: auto;
		overflow-x: hidden;
		word-break: break-word;
		overflow-wrap: break-word;
	}

	.content :global(table) {
		display: block;
		overflow-x: auto;
		white-space: nowrap;
		max-width: 100%;
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4),
	.content :global(h5) {
		margin: 1.5rem 0;
	}

	.content :global(img) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.content :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.1;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		color: var(--gray-0);
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.content :global(blockquote) {
			font-size: var(--text-2xl);
		}
	}
</style>
