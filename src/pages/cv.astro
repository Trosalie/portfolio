---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV | Thibault Rosalie" description="Curriculum Vitae de Thibault Rosalie - Développeur FullStack, étudiant en BUT 3 Informatique">
	<main class="cv-wrapper">
		<div class="cv-actions">
			<a href="/cv-print/" target="_blank" rel="noopener" class="btn-download">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
				</svg>
				Sauvegarder en PDF
			</a>
		</div>

		<article class="cv" aria-label="Curriculum Vitae de Thibault Rosalie">
			<!-- EN-TÊTE -->
			<header class="cv-header">
				<div class="cv-header-identity">
					<h1 class="cv-name">Thibault <span>Rosalie</span></h1>
					<p class="cv-age">22 ans</p>
				</div>
				<p class="cv-title">Développeur FullStack</p>
			</header>

			<div class="cv-body">
				<!-- COLONNE GAUCHE -->
				<aside class="cv-sidebar" aria-label="Informations personnelles">

					<section class="cv-section">
						<h2 class="cv-section-title">Profil</h2>
						<p class="cv-profile-text">
							Actuellement en BUT 3 Informatique, je recherche un stage de 14 à 16 semaines
							pour mettre en pratique mes compétences.
						</p>
						<p class="cv-profile-text">
							Curieux et rigoureux, je souhaite contribuer à des projets concrets et techniques,
							tout en consolidant mon sens du travail en équipe.
						</p>
					</section>

					<section class="cv-section">
						<h2 class="cv-section-title">Coordonnées</h2>
						<ul class="cv-contact-list">
							<li>
								<span class="cv-contact-icon" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
								</span>
								<span>18 Avenue de Sainte-Croix<br />64100 Bayonne</span>
							</li>
							<li>
								<span class="cv-contact-icon" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 9c1.27 2.3 3.06 4.09 5.36 5.36l.94-.94a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21 15.92v1z"/></svg>
								</span>
								<a href="tel:+33760299913">07 60 29 99 13</a>
							</li>
							<li>
								<span class="cv-contact-icon" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
								</span>
								<a href="mailto:thibaultrosaliepro@gmail.com">thibaultrosaliepro@gmail.com</a>
							</li>
							<li>
								<span class="cv-contact-icon" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
								</span>
								<a href="https://linkedin.com/in/thibaultrosalie" target="_blank" rel="noopener noreferrer">thibaultrosalie</a>
							</li>
							<li>
								<span class="cv-contact-icon" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
								</span>
								<a href="https://github.com/trosalie" target="_blank" rel="noopener noreferrer">github.com/trosalie</a>
							</li>
							<li>
								<span class="cv-contact-icon" aria-hidden="true">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
								</span>
								<a href="https://trosalie.alwaysdata.net" target="_blank" rel="noopener noreferrer">trosalie.alwaysdata.net</a>
							</li>
						</ul>
					</section>

					<section class="cv-section">
						<h2 class="cv-section-title">Compétences</h2>
						<ul class="cv-skills-list">
							<li><span class="cv-skill">PHP</span></li>
							<li><span class="cv-skill">Laravel</span></li>
							<li><span class="cv-skill">Angular</span></li>
							<li><span class="cv-skill">Docker</span></li>
							<li><span class="cv-skill">MySQL</span></li>
							<li><span class="cv-skill">PHPUnit</span></li>
							<li><span class="cv-skill">Python</span></li>
							<li><span class="cv-skill">SCRUM</span></li>
							<li><span class="cv-skill">Git / GitHub</span></li>
							<li><span class="cv-skill">POO</span></li>
						</ul>
					</section>

					<section class="cv-section">
						<h2 class="cv-section-title">Langues</h2>
						<ul class="cv-lang-list">
							<li>
								<span class="cv-lang-name">Anglais</span>
								<span class="cv-lang-level">Niveau B2</span>
							</li>
							<li>
								<span class="cv-lang-name">Créole Réunionnais</span>
								<span class="cv-lang-level">Natif</span>
							</li>
						</ul>
					</section>

					<section class="cv-section">
						<h2 class="cv-section-title">Loisirs</h2>
						<ul class="cv-hobbies-list">
							<li>Jeux vidéo</li>
							<li>Randonnée</li>
							<li>Musculation</li>
							<li>Yoseikan Budo</li>
						</ul>
					</section>
				</aside>

				<!-- COLONNE DROITE -->
				<section class="cv-main" aria-label="Parcours">

					<section class="cv-section">
						<h2 class="cv-section-title cv-section-title--main">Formation</h2>

						<article class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3 class="cv-entry-title">BUT Informatique</h3>
									<p class="cv-entry-place">IUT de Bayonne et du Pays Basque</p>
								</div>
								<time class="cv-entry-date">2023 – 2026</time>
							</div>
							<ul class="cv-entry-list">
								<li>Développement informatique</li>
								<li>Optimisation d'applications</li>
								<li>Administration de systèmes communicants</li>
								<li>Conception / Gestion / Administration / Exploitation de base de données</li>
								<li>Gestion de projet agile</li>
								<li>Travail en équipe informatique</li>
							</ul>
						</article>

						<article class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3 class="cv-entry-title">BUT Génie Électrique et Informatique Industrielle</h3>
									<p class="cv-entry-place">IUT de Bordeaux Gradignan</p>
								</div>
								<time class="cv-entry-date">2021 – 2022</time>
							</div>
							<ul class="cv-entry-list">
								<li>Conception de prototype à partir de cahier des charges complet et précis</li>
								<li>Mise en place de protocoles de tests et de mesures</li>
								<li>Conception et vérification de la partie électrique et informatique d'un système</li>
							</ul>
						</article>
					</section>

					<section class="cv-section">
						<h2 class="cv-section-title cv-section-title--main">Projets d'étude</h2>

						<article class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3 class="cv-entry-title">Application Web Responsive</h3>
									<p class="cv-entry-subtitle">Laravel / Angular — SportPxl Dashboard</p>
									<p class="cv-entry-place">IUT de Bayonne et du Pays Basque</p>
								</div>
								<time class="cv-entry-date">2025 – 2026</time>
							</div>
							<ul class="cv-entry-list">
								<li>Gestion de projet agile SCRUM</li>
								<li>Architecture MVC — POO</li>
								<li>Conteneurisation Docker</li>
								<li>Gestion et sécurisation de base de données MySQL</li>
								<li>Rédaction de tests unitaires</li>
							</ul>
						</article>

						<article class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3 class="cv-entry-title">Application Web de Covoiturage</h3>
									<p class="cv-entry-subtitle">PHP / Twig / Bootstrap — Covoit'Étud</p>
									<p class="cv-entry-place">IUT de Bayonne et du Pays Basque</p>
								</div>
								<time class="cv-entry-date">2024 – 2025</time>
							</div>
							<ul class="cv-entry-list">
								<li>Développement fullstack en équipe de 5 — Architecture MVC</li>
								<li>Système de réservation de trajets conducteur / passager</li>
								<li>Intégration d'une API de géocodage pour la carte des trajets</li>
								<li>Gestion de profils étudiants, notation et système de badges</li>
								<li>Documentation technique avec Doxygen</li>
							</ul>
						</article>
					</section>

					<section class="cv-section">
						<h2 class="cv-section-title cv-section-title--main">Expérience professionnelle</h2>

						<article class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3 class="cv-entry-title">Stagiaire en Recherche et Développement</h3>
									<p class="cv-entry-place">
										LIUPPA — Laboratoire Informatique de l'UPPA
									</p>
								</div>
								<time class="cv-entry-date">Mai – Juil. 2025</time>
							</div>
							<ul class="cv-entry-list">
								<li>État de l'art des outils de classification sémantique</li>
								<li>Collecte et analyse de données</li>
								<li>Conception et réalisation de scripts Python de classification de données structurées et semi-structurées</li>
							</ul>
						</article>
					</section>
				</section>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	/* ── Conteneur global ── */
	.cv-wrapper {
		max-width: 960px;
		margin: 2rem auto 4rem;
		padding: 0 1rem;
	}

	/* ── Bouton téléchargement ── */
	.cv-actions {
		display: flex;
		justify-content: flex-end;
		margin-bottom: 1.25rem;
	}

	.btn-download {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--gradient-accent);
		color: var(--accent-text-over);
		padding: 0.6rem 1.25rem;
		border-radius: 999px;
		font-size: var(--text-sm);
		font-weight: 600;
		text-decoration: none;
		transition: opacity var(--theme-transition), box-shadow var(--theme-transition);
		box-shadow: var(--shadow-md);
	}

	.btn-download:hover {
		opacity: 0.85;
		box-shadow: var(--shadow-lg);
	}

	/* ── CV Card ── */
	.cv {
		background: var(--gray-999);
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-lg);
	}

	/* ── En-tête ── */
	.cv-header {
		background: var(--gradient-accent);
		color: var(--accent-text-over);
		padding: 2rem 2.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.cv-header-identity {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.cv-name {
		font-family: var(--font-brand);
		font-size: clamp(1.6rem, 4vw, 2.5rem);
		font-weight: 700;
		margin: 0;
		letter-spacing: 0.02em;
	}

	.cv-name span {
		font-weight: 300;
	}

	.cv-age {
		font-size: var(--text-sm);
		opacity: 0.8;
		margin: 0;
	}

	.cv-title {
		font-size: var(--text-md);
		font-weight: 400;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		opacity: 0.9;
		margin: 0;
	}

	/* ── Corps (deux colonnes) ── */
	.cv-body {
		display: grid;
		grid-template-columns: 260px 1fr;
	}

	/* ── Sidebar gauche ── */
	.cv-sidebar {
		background: var(--accent-dark);
		color: var(--gray-999);
		padding: 1.75rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}

	:root.theme-dark .cv-sidebar {
		background: var(--gray-800);
		color: var(--gray-0);
	}

	/* ── Colonne droite ── */
	.cv-main {
		padding: 1.75rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		background: var(--gray-999);
	}

	/* ── Sections ── */
	.cv-section {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.cv-section-title {
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--accent-light);
		padding-bottom: 0.4rem;
		border-bottom: 1px solid rgba(197, 97, 246, 0.35);
		margin: 0;
	}

	:root.theme-dark .cv-sidebar .cv-section-title {
		color: var(--accent-dark);
		border-bottom-color: rgba(197, 97, 246, 0.3);
	}

	:root.theme-dark .cv-sidebar .cv-contact-list a:hover {
		color: var(--accent-dark);
	}

	.cv-section-title--main {
		color: var(--accent-regular);
		border-bottom-color: var(--accent-overlay);
	}

	:root.theme-dark .cv-section-title--main {
		color: var(--accent-dark);
		border-bottom-color: rgba(197, 97, 246, 0.3);
	}

	/* ── Profil ── */
	.cv-profile-text {
		font-size: var(--text-sm);
		line-height: 1.6;
		margin: 0;
		opacity: 0.9;
	}

	/* ── Coordonnées ── */
	.cv-contact-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.cv-contact-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		font-size: var(--text-sm);
		line-height: 1.5;
	}

	.cv-contact-icon {
		flex-shrink: 0;
		margin-top: 0.15rem;
		opacity: 0.75;
	}

	.cv-contact-list a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.cv-contact-list a[href^="mailto:"] {
		font-size: 0.75rem;
	}

	.cv-contact-list a:hover {
		color: var(--accent-light);
	}

	/* ── Compétences ── */
	.cv-skills-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.cv-skill {
		display: inline-block;
		background: rgba(197, 97, 246, 0.18);
		border: 1px solid rgba(197, 97, 246, 0.4);
		color: var(--accent-light);
		border-radius: 999px;
		padding: 0.2rem 0.7rem;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.03em;
	}

	:root.theme-dark .cv-sidebar .cv-skill {
		background: rgba(197, 97, 246, 0.15);
		color: var(--accent-dark);
		border-color: rgba(197, 97, 246, 0.45);
	}

	:root.theme-dark .cv-skill {
		background: rgba(118, 17, 166, 0.25);
		color: var(--accent-dark);
		border-color: rgba(118, 17, 166, 0.5);
	}

	/* ── Langues ── */
	.cv-lang-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.cv-lang-list li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: var(--text-sm);
		gap: 0.5rem;
	}

	.cv-lang-name {
		font-weight: 600;
	}

	.cv-lang-level {
		font-size: 0.78rem;
		opacity: 0.7;
		background: rgba(197, 97, 246, 0.15);
		border-radius: 999px;
		padding: 0.15rem 0.55rem;
	}

	/* ── Loisirs ── */
	.cv-hobbies-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.cv-hobbies-list li {
		font-size: var(--text-sm);
		line-height: 1.5;
		padding-left: 0.85rem;
		position: relative;
	}

	.cv-hobbies-list li::before {
		content: '▸';
		position: absolute;
		left: 0;
		color: rgba(197, 97, 246, 0.7);
		font-size: 0.65rem;
		top: 0.2rem;
	}

	/* ── Entrées (diplômes / projets / expériences) ── */
	.cv-entry {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding-left: 0.75rem;
		border-left: 3px solid var(--accent-overlay);
		transition: border-color var(--theme-transition);
	}

	.cv-entry:hover {
		border-left-color: var(--accent-regular);
	}

	.cv-entry-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.cv-entry-title {
		font-size: var(--text-base);
		font-weight: 700;
		color: var(--gray-0);
		margin: 0;
		line-height: 1.3;
	}

	.cv-entry-subtitle {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--accent-regular);
		margin: 0.1rem 0 0;
	}

	:root.theme-dark .cv-entry-subtitle {
		color: var(--accent-dark);
	}

	.cv-entry-place {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0.15rem 0 0;
		font-style: italic;
	}

	.cv-entry-date {
		flex-shrink: 0;
		font-size: var(--text-sm);
		font-weight: 700;
		color: var(--accent-regular);
		background: var(--accent-overlay);
		padding: 0.2rem 0.65rem;
		border-radius: 999px;
		white-space: nowrap;
	}

	:root.theme-dark .cv-entry-date {
		color: var(--accent-dark);
	}

	.cv-entry-list {
		margin: 0;
